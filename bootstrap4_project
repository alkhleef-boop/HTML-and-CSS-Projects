<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Academy Cinemas</title>

<link rel="stylesheet"
href="https://cdn.jsdelivr.net/npm/bootstrap@4.1.3/dist/css/bootstrap.min.css">

</head>

<body>

<div class="container">

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-info">
<a class="navbar-brand" href="#">Academy Cinemas</a>

<ul class="navbar-nav">
<li class="nav-item">
<a class="nav-link" href="#">About</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">Showtimes</a>
</li>

<li class="nav-item">
<a class="nav-link" href="#">Deals</a>
</li>
</ul>
</nav>

<!-- Title -->
<div class="jumbotron bg-info text-white text-center">
<h1>Academy Cinemas</h1>
<p>Sit back, relax, and enjoy the show!</p>
</div>

<!-- Movies -->
<div class="row">

<div class="col-md-4">
<div class="card">
<div class="card-body">
<h5 class="card-title">Kong: Skull Island</h5>
<p class="card-text">Adventure movie on a mysterious island.</p>
</div>
</div>
</div>

<div class="col-md-4">
<div class="card">
<div class="card-body">
<h5 class="card-title">Ghost in the Shell</h5>
<p class="card-text">Cyber enhanced soldier fighting crime.</p>
</div>
</div>
</div>

<div class="col-md-4">
<div class="card">
<div class="card-body">
<h5 class="card-title">Beauty and the Beast</h5>
<p class="card-text">Classic story about love and a cursed prince.</p>
</div>
</div>
</div>

</div>

<!-- Email signup -->
<div class="text-center mt-5">
<h3>Sign up for Movie Rewards</h3>
<input type="email" placeholder="Enter email">
<button class="btn btn-primary">Submit</button>
</div>

</div>

</body>
</html>
